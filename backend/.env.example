# Server
PORT=4000
CLIENT_URL=http://localhost:5173

# Database (Postgres - Railway/Supabase/Neon connection string)
DATABASE_URL="postgresql://user:password@localhost:5432/rent_flatmate?schema=public"

# Auth
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# LLM (Anthropic). Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6
LLM_TIMEOUT_MS=8000

# Email (choose one setup)
# Option A: Gmail SMTP (use an App Password, not your normal password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Rent & Flatmate Finder <no-reply@example.com>"

# High-score notification threshold
HIGH_SCORE_THRESHOLD=80
